---
import '../index.css';
import '../components/Button.css';
import '../components/StatusBadge.css';
import '../components/OfferingCard.css';

const {
  lang = 'en',
  title = 'eixo.design | UX Design Consultancy Amsterdam | Workshops & Strategy',
  description = 'Amsterdam-based UX consultancy specializing in workshops, design systems, and strategic discovery. 18 years helping teams align and build better products.',
} = Astro.props;

const canonicalUrl = lang === 'en' ? 'https://eixo.design/' : 'https://eixo.design/pt/';
const ogLocale = lang === 'en' ? 'en_US' : 'pt_BR';
const ogTitle = lang === 'en'
  ? 'eixo.design | UX Design Consultancy Amsterdam'
  : 'eixo.design | Consultoria de UX Design Amsterdã';
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover" />

    <!-- Mobile Web App Capabilities -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="eixo.design" />
    <meta name="application-name" content="eixo.design" />
    <meta name="theme-color" content="#000000" />
    <meta name="msapplication-navbutton-color" content="#000000" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="UX design Amsterdam, design consultancy, UX workshops, design systems, strategic discovery, product design, service design, UX strategy, design thinking" />
    <meta name="author" content="Natalia Arsand, eixo.design" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="language" content={lang === 'en' ? 'English' : 'Portuguese'} />
    <meta name="revisit-after" content="7 days" />
    <meta name="geo.region" content="NL-NH" />
    <meta name="geo.placename" content="Amsterdam" />
    <meta name="rating" content="general" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/eixo-favicon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="eixo.design" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content="https://eixo.design/og-image.png" />
    <meta property="og:image:alt" content="eixo.design — UX Design Consultancy Amsterdam" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@nataliarsand" />
    <meta name="twitter:site" content="@eixodesign" />
    <meta name="twitter:image" content="https://eixo.design/og-image.png" />

    <!-- Performance-Optimized Font Loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap"></noscript>

    <!-- Performance Hints -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preload" as="image" href="/assets/images/eixo-logo-white.png" />
    <link rel="preload" as="image" href="/assets/images/eixo-icon-white.png" />

    <!-- Canonical & Hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href="https://eixo.design/" />
    <link rel="alternate" hreflang="pt" href="https://eixo.design/pt/" />
    <link rel="alternate" hreflang="x-default" href="https://eixo.design/" />

    <!-- Google tag (gtag.js) — loaded only after cookie consent -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      function loadGA() {
        if (document.querySelector('script[src*="googletagmanager"]')) return;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-DZC7SVEFE1';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-DZC7SVEFE1');
      }
      if (location.hostname !== 'localhost' && location.hostname !== '127.0.0.1' && localStorage.getItem('cookie-consent') === 'accepted') loadGA();
    </script>

    <!-- Structured Data / Schema Markup -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "eixo.design",
      "url": "https://eixo.design",
      "logo": "https://eixo.design/assets/images/eixo-icon-white.png",
      "image": "https://eixo.design/og-image.png",
      "description": "Amsterdam-based UX consultancy specializing in workshops, design systems, and strategic discovery. Helping teams align and build better products.",
      "priceRange": "$$",
      "founder": {
        "@type": "Person",
        "name": "Natalia Arsand",
        "jobTitle": "UX Design Lead & Founder",
        "url": "https://eixo.design/#about",
        "knowsAbout": ["UX Design", "Design Systems", "Service Design", "Design Thinking", "Workshop Facilitation"],
        "worksFor": { "@type": "Organization", "name": "eixo.design" }
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@eixo.design",
        "contactType": "customer service",
        "availableLanguage": ["English", "Portuguese"]
      },
      "sameAs": ["https://nataliarsand.github.io/"],
      "address": { "@type": "PostalAddress", "addressLocality": "Amsterdam", "addressCountry": "NL" },
      "areaServed": "Worldwide",
      "knowsLanguage": ["English", "Portuguese"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "UX Design Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "UX Consultancy & Workshops", "description": "Strategic workshops for discovery, alignment, and prioritization. Including systems mapping, experience strategy, and organisational alignment." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Design Systems & Delivery", "description": "UX/UI design for web and mobile, design system setup and documentation, internal tools, and developer collaboration." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "UX Courses", "description": "UX foundations, crash courses for PMs and leaders, problem-framing workshops, and design maturity training." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Design Mentoring", "description": "1:1 mentoring for designers, leaders, and creatives. Career alignment, confidence building, and long-term guidance." } }
        ]
      },
      "review": [
        { "@type": "Review", "reviewBody": "The workshop pushed us to think deeply about our business. The documentation that followed was clear and actionable.", "author": { "@type": "Person", "name": "Leadership Team" }, "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" } },
        { "@type": "Review", "reviewBody": "Natalia brings strong facilitation and design skills. The workshop she ran for us was exceptionally well-structured.", "author": { "@type": "Person", "name": "Accessibility & Inclusion Strategist" }, "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" } }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "reviewCount": "4", "bestRating": "5" }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "eixo.design",
      "url": "https://eixo.design",
      "description": "Amsterdam-based UX design consultancy offering workshops, design systems, courses, and mentoring.",
      "inLanguage": ["en", "pt"]
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "eixo.design — UX Design Consultancy Amsterdam",
      "description": description,
      "url": canonicalUrl,
      "isPartOf": { "@type": "WebSite", "name": "eixo.design", "url": "https://eixo.design" },
      "about": { "@type": "Thing", "name": "UX Design Services" },
      "mainEntity": { "@type": "ProfessionalService", "name": "eixo.design" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["#hero h1", "#hero p", "#about p", "#offerings h3"] },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://eixo.design/" },
          { "@type": "ListItem", "position": 2, "name": "About", "item": "https://eixo.design/#about" },
          { "@type": "ListItem", "position": 3, "name": "Offerings", "item": "https://eixo.design/#offerings" },
          { "@type": "ListItem", "position": 4, "name": "Contact", "item": "https://eixo.design/#contact" }
        ]
      }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What UX design services does eixo.design offer?", "acceptedAnswer": { "@type": "Answer", "text": "eixo.design offers UX consultancy and workshops, design system setup and documentation, UX/UI design and delivery for web and mobile, UX courses for teams and leaders, and 1:1 design mentoring." } },
        { "@type": "Question", "name": "Where is eixo.design located?", "acceptedAnswer": { "@type": "Answer", "text": "eixo.design is based in Amsterdam, Netherlands, and works with clients worldwide." } },
        { "@type": "Question", "name": "Who is behind eixo.design?", "acceptedAnswer": { "@type": "Answer", "text": "eixo.design was founded by Natalia Arsand, a UX Design Lead with 18 years of experience across Dell, ThoughtWorks, startups, and Booking.com, where she led design systems at scale." } },
        { "@type": "Question", "name": "How can I contact eixo.design?", "acceptedAnswer": { "@type": "Answer", "text": "You can reach eixo.design by emailing hello@eixo.design. They typically respond within 24 hours and are currently available for new projects." } }
      ]
    })} />

    <!-- No-JS fallback -->
    <noscript>
      <style>
        body { opacity: 1 !important; }
        .fade-up { opacity: 1 !important; transform: none !important; }
        .fade-up .section__inner > * { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>
  </head>

  <body>
    <script is:inline>
      document.body.classList.add('page-loaded');
      if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth <= 768) {
        document.documentElement.classList.add('mobile');
      }
    </script>

    <slot />

    <!-- Cookie consent banner -->
    <div class="cookie-banner" id="cookie-banner" role="dialog" aria-label={lang === 'pt' ? 'Consentimento de cookies' : 'Cookie consent'}>
      <p>{lang === 'pt' ? 'Usamos cookies para analytics anônimos. Sem anúncios, sem rastreamento.' : 'We use cookies for anonymous analytics. No ads, no tracking.'}</p>
      <div class="cookie-actions">
        <button class="btn btn--primary btn--sm" id="cookie-accept">{lang === 'pt' ? 'Aceitar' : 'Accept'}</button>
        <button class="btn btn--ghost btn--sm" id="cookie-decline">{lang === 'pt' ? 'Recusar' : 'Decline'}</button>
      </div>
    </div>

    <script is:inline>
      // Cookie consent
      var banner = document.getElementById('cookie-banner');
      if (banner && !localStorage.getItem('cookie-consent')) {
        banner.classList.add('visible');
      }
      document.getElementById('cookie-accept')?.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'accepted');
        banner?.classList.remove('visible');
        if (location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') loadGA();
      });
      document.getElementById('cookie-decline')?.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'declined');
        banner?.classList.remove('visible');
      });
    </script>

    <script>
      // Header menu toggle
      const menuToggle = document.querySelector('.menu-toggle');
      const navMenu = document.querySelector('.nav-menu');
      const navBackdrop = document.querySelector('.nav-backdrop');
      const header = document.querySelector('header');
      const scrollTopBtn = document.querySelector('.scroll-top');

      let menuOpen = false;
      let scrollPosition = 0;
      const isMobile = () => window.innerWidth <= 768;

      function openMenu() {
        menuOpen = true;
        menuToggle?.classList.add('menu-open');
        menuToggle?.setAttribute('aria-expanded', 'true');
        navMenu?.classList.add('open');
        navBackdrop?.classList.add('visible');
        if (isMobile()) {
          scrollPosition = window.scrollY;
          document.body.style.overflow = 'hidden';
          document.body.style.position = 'fixed';
          document.body.style.width = '100%';
          document.body.style.top = `-${scrollPosition}px`;
        }
      }

      function closeMenu() {
        menuOpen = false;
        menuToggle?.classList.remove('menu-open');
        menuToggle?.setAttribute('aria-expanded', 'false');
        navMenu?.classList.remove('open');
        navBackdrop?.classList.remove('visible');
        document.body.style.overflow = '';
        document.body.style.position = '';
        document.body.style.width = '';
        document.body.style.top = '';
        if (scrollPosition > 0) {
          window.scrollTo({ top: scrollPosition });
          scrollPosition = 0;
        }
      }

      menuToggle?.addEventListener('click', (e) => {
        e.preventDefault();
        menuOpen ? closeMenu() : openMenu();
      });

      navBackdrop?.addEventListener('click', closeMenu);

      // Smooth scroll for all hash links
      document.querySelectorAll('a[href^="#"]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          if (menuOpen) closeMenu();
          const targetId = link.getAttribute('href')?.slice(1);
          setTimeout(() => {
            const target = document.getElementById(targetId || '');
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
              history.replaceState(null, '', `#${targetId}`);
            }
          }, 50);
        });
      });

      // Escape key closes menu
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menuOpen) closeMenu();
      });

      // IntersectionObserver for active section tracking + header state
      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('.nav-menu a[href^="#"]');

      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const mobileThreshold = isMobile() ? 0.1 : 0.3;
          if (entry.isIntersecting && entry.intersectionRatio > mobileThreshold) {
            navLinks.forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`);
            });
          }
          if (entry.target.id === 'hero') {
            header?.classList.toggle('active', !entry.isIntersecting);
            scrollTopBtn?.classList.toggle('visible', !entry.isIntersecting);
          }
        });
      }, {
        threshold: [0.1, 0.3],
        rootMargin: isMobile() ? '-30px 0px' : '-50px 0px'
      });

      sections.forEach(section => sectionObserver.observe(section));

      // Fade-up animations via IntersectionObserver
      const fadeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-up').forEach(el => fadeObserver.observe(el));

      // Scroll to top button
      scrollTopBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const hero = document.getElementById('hero');
        if (hero) {
          hero.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      // Prevent saving/downloading work photos
      document.querySelectorAll('.bg-image img, .about-bio-photo img, .photo-strip img').forEach(img => {
        img.addEventListener('contextmenu', e => e.preventDefault());
      });

      // Hash navigation on page load
      const hash = window.location.hash;
      if (hash) {
        setTimeout(() => {
          const target = document.querySelector(hash);
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        }, 100);
      }

      // Contact form submission
      const contactForm = document.getElementById('contact-form');
      if (contactForm) {
        contactForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.target;
          const status = form.querySelector('.form-status');
          const submitBtn = form.querySelector('.form-submit');
          const originalText = submitBtn.textContent;

          // Clear previous errors
          form.querySelectorAll('.form-field.error').forEach(f => f.classList.remove('error'));
          status.className = 'form-status';
          status.textContent = '';

          // Validate required fields
          let valid = true;
          form.querySelectorAll('[required]').forEach(field => {
            if (!field.value.trim()) {
              field.closest('.form-field').classList.add('error');
              valid = false;
            }
          });

          const emailField = form.querySelector('[name="email"]');
          if (emailField.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value)) {
            emailField.closest('.form-field').classList.add('error');
            valid = false;
          }

          if (!valid) return;

          submitBtn.disabled = true;
          submitBtn.textContent = submitBtn.dataset.sending || 'Sending...';

          const data = Object.fromEntries(new FormData(form));

          try {
            const res = await fetch('https://eixo-contact.nataliarsand.workers.dev', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });

            if (res.ok) {
              status.className = 'form-status success';
              status.textContent = submitBtn.dataset.success || 'Message sent. We\u2019ll be in touch soon.';
              form.reset();
            } else {
              throw new Error('Failed');
            }
          } catch {
            status.className = 'form-status error';
            status.textContent = submitBtn.dataset.error || 'Something went wrong. Please email us at hello@eixo.design';
          } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        });
      }
    </script>
  </body>
</html>
