---
import Layout from '../../layouts/Layout.astro';
import { content, offerings } from '../../content';
import Accordion from '../../components/Accordion.jsx';
import Testimonials from '../../components/Testimonials.jsx';

const lang = 'pt';
const t = content[lang];
const navItems = t.navItems || [];
---

<Layout
  lang="pt"
  title="eixo.design | Consultoria de UX Design Amsterdã | Workshops & Estratégia"
  description="Consultoria de UX baseada em Amsterdã, especializada em workshops, design systems e descoberta estratégica. 18 anos ajudando times a alinhar e construir produtos melhores."
>
  <div class="app">
    <div class="bg-noise"></div>

    <header>
      <a href="#hero">
        <img src="/assets/images/eixo-logo-white.png" alt="Eixo Logo" class="logo" />
      </a>
      <button
        class="menu-toggle"
        aria-label={t.navigation.openMenu}
        aria-expanded="false"
      >
        <span class="hamburger-line" aria-hidden="true"></span>
        <span class="hamburger-line" aria-hidden="true"></span>
        <span class="hamburger-line" aria-hidden="true"></span>
      </button>
      <div class="nav-backdrop" aria-hidden="true"></div>
      <nav class="nav-menu" aria-label={t.navigation.menuLabel}>
        <div class="nav-menu-content">
          <ul>
            {navItems.map(item => (
              <li><a href={`#${item.id}`}>{item.label}</a></li>
            ))}
          </ul>
          <div class="mobile-nav-ctas">
            <a href="#contact" class="btn btn--primary btn--sm">Contato</a>
            <a href="https://calendar.app.google/bzxUPATwJy5Wkuhd6" target="_blank" rel="noopener noreferrer" class="btn btn--secondary btn--sm">Agendar call</a>
          </div>
          <div class="mobile-lang-switcher">
            <span class="lang-label">{t.navigation.languageLabel}</span>
            <div class="lang-buttons">
              <a href="/" class="btn btn--ghost btn--sm" aria-label="Switch to English">EN</a>
              <a href="/pt/" class="btn btn--ghost btn--sm active" aria-label="Mudar para Português">PT</a>
            </div>
          </div>
        </div>
      </nav>
      <div class="header-right">
        <span class="status-badge status-badge--online header-status">
          <span class="status-badge__dot"></span>
          <span class="status-badge__text">{t.socialProof.availability}</span>
        </span>
        <div class="header-ctas">
          <a href="#contact" class="btn btn--primary btn--sm">Contato</a>
          <a href="https://calendar.app.google/bzxUPATwJy5Wkuhd6" target="_blank" rel="noopener noreferrer" class="btn btn--secondary btn--sm">Agendar call</a>
        </div>
        <div class="desktop-lang-switcher">
          <a href="/" class="lang-link">EN</a>
          <span class="lang-sep">/</span>
          <a href="/pt/" class="lang-link active">PT</a>
        </div>
      </div>
    </header>

    <main>
      <section class="section section--left fade-up" id="hero">
        <div class="bg-image" aria-hidden="true">
          <img src="/assets/images/work-photos/IMG_0490.JPG" alt="" loading="eager" draggable="false" />
        </div>
        <div class="section__inner">
          <div class="hero-layout">
            <img src="/assets/images/eixo-icon-white.png" alt="Eixo Icon" class="hero-x" />
            <h1>
              <span class="line1">{t.subtitle1}</span>
              <span class="line2">{t.subtitle2}</span>
            </h1>
            {t.pronunciation && <p class="pronunciation">{t.pronunciation}</p>}
            <p class="hero-lead">{t.heroLead}</p>
            <div class="cta-container">
              <a href="#contact" class="btn btn--primary btn--md">
                {t.heroCta}
              </a>
            </div>
          </div>
          <a href="#offerings" class="scroll-hint" aria-label="Rolar para baixo">
            <span class="scroll-hint__arrow"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M19 12l-7 7-7-7"/></svg></span>
          </a>
        </div>
      </section>

      <section class="section fade-up" id="offerings">
        <div class="section__inner offerings-inner">
          <h3 class="offerings-label">{t.offeringsLabel}</h3>
          <div class="offerings-content">
            <div class="offerings-axis">
              <span class="offerings-axis__title">{offerings[0].title[lang]}</span>
              <span class="offerings-axis__title">{offerings[1].title[lang]}</span>
            </div>

            <div class="offerings-split">
              {offerings.slice(0, 2).map(offering => (
                <div class="offerings-col">
                  <p class="offerings-col__subtitle">{offering.subtitle[lang]}</p>
                  <div class="offerings-col__when">
                    <span class="offerings-col__when-label">{t.offeringsWhenLabel}</span>
                    <p>{offering.when[lang]}</p>
                  </div>
                  <ul>
                    {offering.bullets[lang].map(bullet => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>

          <div class="offerings-also-row">
            <span class="offerings-also-label">{t.offeringsAlsoLabel}</span>
            <div class="offerings-also-items">
              {offerings.slice(2).map(offering => (
                <div class="offerings-also-item">
                  <span class="offerings-also-item__title">{offering.title[lang]}</span>
                  <span class="offerings-also-item__sub">{offering.subtitle[lang]}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="cta-container">
            <a href="#contact" class="btn btn--primary btn--md">
              {t.cta}
            </a>
          </div>
        </div>
      </section>

      <div class="photo-strip fade-up" aria-hidden="true">
        <div class="bg-image">
          <img src="/assets/images/work-photos/IMG_3579.JPG" alt="" loading="lazy" draggable="false" />
        </div>
      </div>

      <section class="section section--left fade-up" id="methodology">
        <div class="section__inner">
          <h3>{t.aboutPrinciplesTitle}</h3>
          {t.aboutMethodIntro && <p class="method-intro">{t.aboutMethodIntro}</p>}
          <div class="section__split">
            <Accordion items={t.aboutPrinciples} client:load />
            <div class="accordion-image">
              <img src="/assets/images/work2.png" alt="Parede de design" />
            </div>
          </div>
          <div class="cta-container">
            <a href="#contact" class="btn btn--primary btn--md">
              {t.cta}
            </a>
          </div>
        </div>
      </section>

      <div class="photo-strip photo-strip--second fade-up" aria-hidden="true">
        <div class="bg-image">
          <img src="/assets/images/work-photos/IMG_1694.jpeg" alt="" loading="lazy" draggable="false" />
        </div>
      </div>

      <section class="section section--left fade-up" id="testimonials">
        <div class="section__inner">
          <h3>{t.testimonialsTitle}</h3>
          <Testimonials testimonials={t.testimonials} client:load />
          <div class="cta-container">
            <a href="#contact" class="btn btn--primary btn--md">
              {t.cta}
            </a>
          </div>
        </div>
      </section>

      <section class="section section--left fade-up" id="about">
        <div class="section__inner">
          <div class="about-card">
            <img src="/assets/images/eixo-icon-white.png" alt="" class="about-icon" aria-hidden="true" />
            <h3>{t.aboutTitle}</h3>
            <p>{t.aboutText1}</p>
            <p>{t.aboutText2}</p>
            <p class="strong">{t.aboutText3}</p>
          </div>
          <div class="about-bio">
            <div class="about-bio-text">
              <h3>{t.bioTitle}</h3>
              <p>{t.bioText1}</p>
              <p>{t.bioText2}</p>
              <p class="strong">{t.bioText3}</p>
            </div>
            <div class="about-bio-photo">
              <img src="/assets/images/work-photos/natalia/2024-03-20 Natalia-1229-by Ellard Vasen_JpegMini_C1.jpg" alt="Natalia Arsand, fundadora da eixo.design" loading="lazy" />
            </div>
          </div>
          <div class="cta-container">
            <a href="#contact" class="btn btn--secondary btn--md">
              Trabalhe conosco
            </a>
          </div>
        </div>
      </section>

      <section class="section section--left fade-up" id="contact">
        <div class="section__inner">
          <h3>{t.contactTitle}</h3>
          <div class="contact-layout">
            <div class="contact-text">
              <p class="contact-intro">{t.contactText}</p>
              <p class="contact-subtext">{t.contactSubtext}</p>
              <div class="contact-details">
                <a href="mailto:hello@eixo.design" class="contact-email">hello@eixo.design</a>
              </div>
            </div>
            <form class="contact-form" id="contact-form" novalidate>
              <div class="form-field">
                <select name="reason" required aria-label={t.contactForm.reason}>
                  <option value="" disabled selected>{t.contactForm.reason}*</option>
                  {t.contactForm.reasonOptions.map(option => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
                <span class="select-arrow" aria-hidden="true"></span>
              </div>
              <div class="form-field">
                <textarea name="message" rows="4" placeholder={t.contactForm.message} aria-label={t.contactForm.message}></textarea>
              </div>
              <div class="form-row">
                <div class="form-field">
                  <input type="text" name="name" placeholder={`${t.contactForm.name}*`} required aria-label={t.contactForm.name} />
                </div>
                <div class="form-field">
                  <input type="email" name="email" placeholder={`${t.contactForm.email}*`} required aria-label={t.contactForm.email} />
                </div>
              </div>
              <div class="form-field">
                <input type="text" name="company" placeholder={t.contactForm.company} aria-label={t.contactForm.company} />
              </div>
              <button type="submit" class="btn btn--primary btn--md form-submit"
                data-sending={t.contactForm.sending}
                data-success={t.contactForm.success}
                data-error={t.contactForm.error}>
                {t.contactForm.submit}
              </button>
              <div class="form-status" aria-live="polite"></div>
            </form>
          </div>
        </div>
      </section>

      <footer class="footer">
        <div class="footer-content">
          <div class="footer-main">
            <div class="footer-info">
              <div class="footer-branding">
                <img class="footer-logo" src="/assets/images/eixo-logo-white.png" alt="Eixo.design logo" />
                {t.footer.availability && (
                  <span class="status-badge status-badge--online">
                    <span class="status-badge__dot"></span>
                    <span class="status-badge__text">{t.footer.availability}</span>
                  </span>
                )}
              </div>
              {t.footer.location && <span class="footer-location">{t.footer.location}</span>}
              <a href={`mailto:${t.footer.email}`} class="footer-contact">{t.footer.email}</a>
            </div>
            <div class="footer-brand">
              <span class="footer-name">&copy; {new Date().getFullYear()} eixo.design</span>
              {t.footer.description && <p class="footer-description">{t.footer.description}</p>}
              <a href="/privacy/" target="_blank" rel="noopener noreferrer" class="footer-legal">Política de Privacidade</a>
            </div>
          </div>
        </div>
      </footer>
    </main>

    <button class="scroll-top" aria-label={t.navigation.backToTop} type="button"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg></button>
  </div>
</Layout>
